<!doctype html>
<html>

<head>
  <%- include('../partials/head', { title: 'Edit Profile', styles: ['products', 'admin'] }) %>
</head>
<body>
  <header class="site-header"><div class="container"><a class="logo" href="/">SamCosmetics</a></div></header>
  <main class="container admin-main" style="max-width:600px">
    <h1>Edit Profile</h1>

    <form method="post" action="/account/edit" class="form-grid">
      <div class="form-field">
        <label>Name</label>
        <input name="name" value="<%= customer.name || '' %>"/>
      </div>
      <div class="form-field">
        <label>Email (readonly)</label>
        <input value="<%= customer.email || '' %>" readonly/>
      </div>
      <div class="form-field">
        <label>Phone</label>
        <input name="phone" value="<%= customer.phone || '' %>"/>
      </div>
      <div class="form-field">
        <label>Address</label>
        <textarea name="address"><%= customer.address || '' %></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-pink">Save</button>
        <a href="/account" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </main>
</body>
</html>