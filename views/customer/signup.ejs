<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Create Account</title>
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/admin.css"/>
</head>
<body>
  <header class="site-header"><div class="container"><a class="logo" href="/">SamCosmetics</a></div></header>
  <main class="container admin-main" style="max-width:460px">
    <h1>Create Account</h1>

    <% if (typeof error !== 'undefined') { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <form method="post" action="/signup" class="form-grid">
      <div class="form-field">
        <label>Full name</label>
        <input name="name" required/>
      </div>
      <div class="form-field">
        <label>Email</label>
        <input name="email" type="email" required/>
      </div>
      <div class="form-field">
        <label>Password</label>
        <input name="password" type="password" required/>
      </div>
      <div class="form-field">
        <label>Phone (optional)</label>
        <input name="phone"/>
      </div>
      <div class="form-field">
        <label>Address (optional)</label>
        <textarea name="address"></textarea>
      </div>
      <div>
        <button type="submit" class="btn btn-pink">Create Account</button>
      </div>
    </form>

    <p style="margin-top:1rem">Already have an account? <a href="/login">Log in</a></p>
  </main>
</body>
</html>