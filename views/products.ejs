<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Shop - SamCosmetics</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/css/products.css" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="logo" href="/">SamCosmetics</a>
      <nav>
        <a href="/">Home</a>
        <a href="wishlist">wishlist</a>
        <a href="/contact">Contact</a>
        <a id="cart-link" href="/cart">Cart (<span id="cart-count"><%= cartCount %></span>)</a>
      </nav>
    </div>
  </header>

  <main class="container products-page">
    <h1>Shop</h1>
    <div id="product-grid" class="product-grid">
      <% if (Array.isArray(products) && products.length) { %>
        <% products.forEach(function(p){ %>
          <div class="card" data-id="<%= p.id %>">
            <button class="wish" data-id="<%= p.id %>" title="Add to wishlist" aria-label="wishlist">♡</button>
            <img src="<%= p.image_url || '/images/placeholder.png' %>" alt="<%= p.name %>">
            <div class="card-body">
              <h3><%= p.name %></h3>
              <p class="short"><%= p.short_description || '' %></p>
              <div class="meta">
                <span class="price">$<%= Number(p.price).toFixed(2) %></span>
                <button class="btn add-bag" data-id="<%= p.id %>">Add to Bag</button>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="loader">No products found.</div>
      <% } %>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">&copy; <span id="year"></span> SamCosmetics</div>
  </footer>

  <script src="/js/product-actions.js"></script>
  <script>document.getElementById('year').textContent = new Date().getFullYear();</script>
</body>
</html>