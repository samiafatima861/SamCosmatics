<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Shop', styles: ['layout', 'products'] }) %>
</head>
<body>

  <%- include('partials/site-header', { cartCount: typeof cartCount !== 'undefined' ? cartCount : 0 }) %>

  <main class="container products-page">
    <h1>Shop</h1>

    <div id="product-grid" class="product-grid">
      <% if (Array.isArray(products) && products.length) { %>
        <% products.forEach(function(p){ %>
          <div class="card" data-id="<%= p.id %>">
            <button class="wish" data-id="<%= p.id %>" title="Add to wishlist" aria-label="wishlist">♡</button>
            <a href="/products/<%= p.id %>" class="card-link-wrap">
              <img src="<%= p.image_url || '/images/placeholder.png' %>" alt="<%= p.name %>">
            </a>
            <div class="card-body">
              <a href="/products/<%= p.id %>" class="card-title-link">
                <h3><%= p.name %></h3>
              </a>
              <p class="short"><%= p.short_description || '' %></p>
              <div class="meta">
                <span class="price">$<%= Number(p.price).toFixed(2) %></span>
                <button class="btn add-bag" data-id="<%= p.id %>">Add to Bag</button>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="loader">No products found.</div>
      <% } %>
    </div>
  </main>

  <%- include('partials/site-footer') %>

  <script src="/js/product-actions.js"></script>
</body>
</html>