<!doctype html>
<html>
<head>
  <%- include('partials/head', { title: 'Order Confirmed', styles: ['layout', 'products', 'order'] }) %>
</head>
<body>

  <%- include('partials/site-header') %>

  <main class="container">
    <div class="order-confirm">
      <div class="check-icon">✓</div>
      <h1>Thank you</h1>
      <p>Your order has been placed.</p>
      <p><strong class="order-id">Order ID: <%= orderId %></strong></p>
      <p>Payment method: Cash on Delivery. We will contact you for delivery details.</p>
      <a href="/products">Continue shopping</a>
    </div>
  </main>

  <%- include('partials/site-footer') %>

</body>
</html>