<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Seller Login', styles: ['products', 'home', 'admin'] }) %>
</head>
<body>

  <%- include('../partials/site-header', { cartCount: typeof cartCount !== 'undefined' ? cartCount : 0 }) %>

  <main class="container page-hero" style="max-width:420px;margin:3rem auto">
    <h1>Seller Login</h1>

    <div class="info-card">
      <% if (typeof error !== 'undefined') { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form method="post" action="/seller/login" class="form-grid">
        <div class="form-field">
          <label>Email</label>
          <input name="email" type="email" required/>
        </div>
        <div class="form-field">
          <label>Password</label>
          <input name="password" type="password" required/>
        </div>
        <div>
          <button type="submit" class="btn btn-pink">Sign in</button>
        </div>
      </form>

      <p style="margin-top:1rem">Don't have an account? <a href="/seller/signup">Apply to sell</a></p>
    </div>
  </main>

  <%- include('../partials/site-footer') %>
</body>
</html>