<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Seller Signup', styles: ['products', 'home', 'admin'] }) %>
</head>
<body>

  <%- include('../partials/site-header', { cartCount: typeof cartCount !== 'undefined' ? cartCount : 0 }) %>

  <main class="container page-hero" style="max-width:500px;margin:3rem auto">
    <h1>Become a Seller</h1>
    <p style="color:#7A6C68;margin-top:-1rem;margin-bottom:1.5rem">Apply to sell your products on SamCosmetics.</p>

    <div class="info-card">
      <% if (typeof error !== 'undefined') { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form method="post" action="/seller/signup" class="form-grid">
        <div class="form-field">
          <label>Full name</label>
          <input name="name" required/>
        </div>
        <div class="form-field">
          <label>Email</label>
          <input name="email" type="email" required/>
        </div>
        <div class="form-field">
          <label>Password</label>
          <input name="password" type="password" required/>
        </div>
        <div class="form-field">
          <label>Phone (optional)</label>
          <input name="phone"/>
        </div>
        <div class="form-field">
          <label>Business address (optional)</label>
          <textarea name="address"></textarea>
        </div>
        <div>
          <button type="submit" class="btn btn-pink">Submit Application</button>
        </div>
      </form>

      <p style="margin-top:1rem">Already have an account? <a href="/seller/login">Log in</a></p>
    </div>
  </main>

  <%- include('../partials/site-footer') %>
</body>
</html>