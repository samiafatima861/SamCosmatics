<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Account Pending</title>
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/order.css"/>
</head>
<body>
  <header class="site-header"><div class="container"><a class="logo" href="/">SamCosmetics</a></div></header>
  <main class="container">
    <div class="order-confirm">
      <h1>Account Pending Approval</h1>
      <p>Hi <%= seller.name %>, your seller account is still awaiting admin review.</p>
      <p>You'll be able to list products once approved.</p>
      <form action="/seller/logout" method="post" style="margin-top:1.5rem">
        <button type="submit" class="btn btn-dark">Logout</button>
      </form>
    </div>
  </main>
</body>
</html>