<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Seller Dashboard', styles: ['products', 'home', 'admin', 'revenue-pro'] }) %>
</head>
<body>

  <%- include('../partials/site-header', { cartCount: typeof cartCount !== 'undefined' ? cartCount : 0 }) %>

  <main class="container admin-main">
    <div class="page-header">
      <h1>My Products</h1>
      <a href="/seller/products/new" class="btn-create">+ Add Product</a>
    </div>

    <% if (!products.length) { %>
      <div class="empty-state">You haven't listed any products yet.</div>
    <% } else { %>
      <div class="pro-panel">
        <table class="pro-table">
          <thead><tr><th>Product</th><th>Price</th><th>Stock</th><th>Actions</th></tr></thead>
          <tbody>
            <% products.forEach(p => { %>
              <tr>
                <td>
                  <div class="pro-product-cell">
                    <img src="<%= p.image_url || '/images/placeholder.png' %>"/>
                    <span><%= p.name %></span>
                  </div>
                </td>
                <td>$<%= Number(p.price).toFixed(2) %></td>
                <td>
                  <% if (p.stock_quantity <= 0) { %>
                    <span class="pro-pill pill-rejected"><%= p.stock_quantity %></span>
                  <% } else if (p.stock_quantity <= 5) { %>
                    <span class="pro-pill pill-pending"><%= p.stock_quantity %></span>
                  <% } else { %>
                    <span class="pro-pill pill-approved"><%= p.stock_quantity %></span>
                  <% } %>
                </td>
                <td>
                  <a href="/seller/products/<%= p.id %>/edit" style="color:#3E7FC4;font-weight:600;text-decoration:none;margin-right:.5rem">Edit</a>
                  <form action="/seller/products/<%= p.id %>/delete" method="post" style="display:inline">
                    <button type="submit" style="background:none;border:none;color:#E0554F;cursor:pointer;font-weight:600;font-size:.9rem">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>

  <%- include('../partials/site-footer') %>
</body>
</html>