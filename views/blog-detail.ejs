<!doctype html>
<html>
<head>
  <%- include('partials/head', { title: blog.title, styles: ['layout'] }) %>
</head>
<body>
  <%- include('partials/site-header') %>
  <main class="container page-hero" style="max-width:760px;margin:3rem auto">
    <% if (blog.cover_image_url) { %><img src="<%= blog.cover_image_url %>" alt="<%= blog.title %>" style="width:100%;border-radius:12px;margin-bottom:1.5rem"/><% } %>
    <h1><%= blog.title %></h1>
    <p class="lede"><%= new Date(blog.created_at).toLocaleDateString() %></p>
    <div class="info-card blog-content"><%- blog.content %></div>
    <p style="margin-top:2rem"><a href="/blog">← Back to Blog</a></p>
  </main>
  <%- include('partials/site-footer') %>
</body>
</html>