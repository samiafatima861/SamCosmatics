<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Admin Login', styles: ['login'] }) %>
</head>
<body>
  <div class="login-overlay-page">

    <!-- blurred live homepage behind the login prompt -->
    <iframe class="login-bg-frame" src="/" tabindex="-1" aria-hidden="true"></iframe>
    <div class="login-scrim"></div>

    <div class="login-modal-wrap">
      <main class="login-modal">
        <div class="login-eyebrow">Admin Console</div>
        <h1>Admin Login</h1>
        <p class="login-sub">Sign in to manage your store.</p>

        <% if (typeof error !== 'undefined') { %>
          <div class="login-error"><%= error %></div>
        <% } %>

        <form method="post" action="/admin/login">
          <div class="login-field">
            <label>Email</label>
            <input name="email" type="email" required autofocus/>
          </div>
          <div class="login-field">
            <label>Password</label>
            <input name="password" type="password" required/>
          </div>
          <div>
            <button type="submit" class="login-submit">Sign in</button>
          </div>
        </form>
      </main>
    </div>

  </div>
</body>
</html>