<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Notifications', styles: ['admin-layout', 'admin'] }) %>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { active: 'notifications' }) %>

    <div class="pro-page">
      <header class="pro-topbar">
        <h2>Notifications</h2>
      </header>

      <div class="pro-content">
        <% if (!notifications.length) { %>
          <div class="empty-state">No notifications yet.</div>
        <% } else { %>
          <div class="notif-list">
            <% notifications.forEach(n => { %>
              <a href="<%= n.link || '#' %>" class="notif-item">
                <div class="notif-icon notif-icon-<%= n.type %>">
                  <% if (n.type === 'order') { %>📦<% } else if (n.type === 'seller_signup') { %>🏪<% } else { %>🧑‍🤝‍🧑<% } %>
                </div>
                <div>
                  <div class="notif-message"><%= n.message %></div>
                  <div class="notif-time"><%= new Date(n.created_at).toLocaleString() %></div>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>