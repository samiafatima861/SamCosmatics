<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Customers', styles: ['admin-layout', 'revenue-pro'] }) %>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { active: 'customers' }) %>

    <div class="pro-page">
      <header class="pro-topbar">
        <h2>Customers</h2>
        <div class="pro-topbar-actions"><button class="pro-icon-btn">🔔</button></div>
      </header>

      <div class="pro-content">
        <div class="pro-stat-grid">
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-blue">🧑‍🤝‍🧑</div>
              <div><div class="pro-stat-title"><%= summary.total %></div><div class="pro-stat-sub">Total Customers</div></div>
            </div>
          </div>
        </div>

        <div class="pro-panel">
          <h3>All Customers</h3>
          <% if (!customers.length) { %>
            <p style="color:#8A8FA3">No customers yet.</p>
          <% } else { %>
            <table class="pro-table">
              <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Joined</th></tr></thead>
              <tbody>
                <% customers.forEach(c => { %>
                  <tr>
                    <td><%= c.name %></td>
                    <td><%= c.email %></td>
                    <td><%= c.phone || '—' %></td>
                    <td><%= new Date(c.created_at).toLocaleDateString() %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>