<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <header class="site-header"><div class="container"><a class="logo" href="/">SamCosmetics</a></div></header>
  <main class="container">
    <div class="page-header">
       <h1>Manage Products</h1>
       <a href="/admin/adminProducts/new" class="btn-create">+ Create New Product</a>
    </div>

    <table class ="product-table">
      <thead><tr><th>#</th><th>Image</th><th>Name</th><th>Price</th><th>Featured</th><th>Actions</th></tr></thead>
      <tbody>
        <% products.forEach(p => { %>
          <tr>
            <td><%= p.id %></td>
            <td><img src="<%= p.image_url || '/images/placeholder.png' %>" style="width:64px;height:64px;object-fit:cover"/></td>
            <td><%= p.name %></td>
            <td>$<%= Number(p.price).toFixed(2) %></td>
            <td><%= p.featured ? 'Yes' : 'No' %></td>
            <td>
              <a href="/admin/adminProducts/<%= p.id %>/edit">Edit</a>
              <form action="/admin/adminProducts/<%= p.id %>/delete" method="post" style="display:inline">
                <button type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>
</body>
</html>


