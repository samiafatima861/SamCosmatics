<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>create-new product</title>
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <header class="site-header"><div class="container"><a class="logo" href="/">SamCosmetics</a></div></header>
  <main class="container admin-main" style="max-width:700px">

    <div class="page-header">
      <h1><%= product.id ? 'Edit Product' : 'Create New Product' %></h1>
    </div>

    <form method="post" enctype="multipart/form-data"
          action="<%= product.id ? '/admin/adminProducts/' + product.id + '/edit' : '/admin/products/new' %>"
          class="form-grid product-form-card">

      <div class="form-field">
        <label>Name</label>
        <input name="name" required value="<%= product.name || '' %>"/>
      </div>

      <div class="form-field">
        <label>Price</label>
        <input name="price" type="number" step="0.01" required value="<%= product.price || 0 %>"/>
      </div>
      <div class="form-field">
        <label>Cost Price (what it costs you)</label>
        <input name="cost_price" type="number" step="0.01" min="0" required value="<%= product.cost_price || 0 %>"/>
      </div>

      <div class="form-field">
        <label>Short description</label>
        <input name="short_description" value="<%= product.short_description || '' %>"/>
      </div>

      <div class="form-field">
        <label>Description</label>
        <textarea name="description" rows="4"><%= product.description || '' %></textarea>
      </div>

      <div class="form-field">
        <label>Image file (optional)</label>
        <% if (product.image_url) { %>
          <img src="<%= product.image_url %>" class="admin-avatar-square"/>
        <% } %>
        <input type="file" name="image" accept="image/*"/>
      </div>

      <div class="form-field">
        <label>Stock Quantity</label>
        <input name="stock_quantity" type="number" min="0" required value="<%= product.stock_quantity ?? 0 %>"/>
     </div>
     <div class="form-field">
  <label>Variants (optional — leave empty for a simple product)</label>
  <div id="variant-rows">
    <% (product.variants || []).forEach((v, i) => { %>
      <div class="variant-row">
        <input type="text" name="variant_name[]" placeholder="Variant name (e.g. Black, Size M)" value="<%= v.variant_name %>"/>
        <input type="number" name="variant_stock[]" placeholder="Stock" min="0" value="<%= v.stock_quantity %>"/>
        <input type="number" name="variant_threshold[]" placeholder="Low stock alert" min="0" value="<%= v.low_stock_threshold %>"/>
        <button type="button" class="btn-remove-variant">✕</button>
      </div>
    <% }) %>
  </div>
  <button type="button" id="add-variant-btn" class="btn btn-secondary">+ Add Variant</button>
</div>

      <div class="form-checkbox">
        <label><input type="checkbox" name="featured" value="1" <%= product.featured ? 'checked' : '' %>/> Featured</label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-pink">Save</button>
        <a href="/admin/adminProducts" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </main>
  <script>
document.getElementById('add-variant-btn').addEventListener('click', () => {
  const wrap = document.getElementById('variant-rows');
  const row = document.createElement('div');
  row.className = 'variant-row';
  row.innerHTML = `
    <input type="text" name="variant_name[]" placeholder="Variant name (e.g. Black, Size M)"/>
    <input type="number" name="variant_stock[]" placeholder="Stock" min="0"/>
    <input type="number" name="variant_threshold[]" placeholder="Low stock alert" min="0"/>
    <button type="button" class="btn-remove-variant">✕</button>
  `;
  wrap.appendChild(row);
});

document.getElementById('variant-rows').addEventListener('click', (e) => {
  if (e.target.matches('.btn-remove-variant')) {
    e.target.closest('.variant-row').remove();
  }
});
</script>
</body>
</html>