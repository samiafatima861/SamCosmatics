<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Profile', styles: ['admin-layout', 'revenue-pro'] }) %>
</head>
<body>
  <div class="admin-layout">

    <%- include('../partials/admin-sidebar', { active: 'dashboard' }) %>

    <!-- Main -->
    <div>
      <header class="admin-topbar">
        <h2>Profile</h2>
        <div class="admin-topbar-account">
          <img src="<%= admin?.image_url || '/images/placeholder.png' %>" alt="admin" class="admin-topbar-avatar"/>
          <span class="admin-topbar-name"><%= admin?.name %></span>
          <form action="/admin/logout" method="post">
            <button type="submit">Logout</button>
          </form>
        </div>
      </header>

      <main class="admin-content">
        <h1>My Profile</h1>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="pro-pill pill-rejected" style="display:inline-block;margin-bottom:1rem;padding:.5rem .9rem;font-size:.85rem"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="pro-pill pill-approved" style="display:inline-block;margin-bottom:1rem;padding:.5rem .9rem;font-size:.85rem"><%= success %></div>
        <% } %>

        <div class="pro-panel-row">

          <!-- Profile summary card -->
          <div class="pro-panel" style="max-width:320px">
            <div style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:.9rem">
              <img src="<%= admin?.image_url || '/images/placeholder.png' %>" alt="admin"
                   style="width:110px;height:110px;border-radius:50%;object-fit:cover;border:3px solid #F4F5F9"/>
              <div>
                <div style="font-family:'Playfair Display',serif;font-weight:700;font-size:1.3rem;color:#1E1E2A"><%= admin?.name %></div>
                <div style="color:#9AA0AE;font-size:.9rem;margin-top:.2rem"><%= admin?.email %></div>
              </div>

              <div style="width:100%;display:flex;flex-direction:column;gap:.6rem;margin-top:.5rem">
                <div class="pro-stat-card" style="padding:.7rem .9rem">
                  <div class="pro-stat-left">
                    <div class="pro-icon-badge badge-blue">📞</div>
                    <div style="text-align:left">
                      <div class="pro-stat-sub" style="margin:0">Phone</div>
                      <div style="font-weight:600;font-size:.9rem"><%= admin?.phone || '—' %></div>
                    </div>
                  </div>
                </div>
                <div class="pro-stat-card" style="padding:.7rem .9rem">
                  <div class="pro-stat-left">
                    <div class="pro-icon-badge badge-orange">📍</div>
                    <div style="text-align:left">
                      <div class="pro-stat-sub" style="margin:0">Address</div>
                      <div style="font-weight:600;font-size:.9rem"><%= admin?.address || '—' %></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Edit profile + password -->
          <div style="flex:1;display:flex;flex-direction:column;gap:1.25rem">

            <div class="pro-panel">
              <h3>Edit Profile</h3>
              <form action="/admin/profile/edit" method="post" enctype="multipart/form-data">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
                  <div>
                    <label style="display:block;font-size:.8rem;color:#5A5F72;margin-bottom:.4rem;font-weight:600">Name</label>
                    <input name="name" value="<%= admin?.name || '' %>"
                           style="width:100%;padding:.6rem .8rem;border:1px solid #E4E4EC;border-radius:8px;font-size:.9rem"/>
                  </div>
                  <div>
                    <label style="display:block;font-size:.8rem;color:#5A5F72;margin-bottom:.4rem;font-weight:600">Email</label>
                    <input name="email" value="<%= admin?.email || '' %>" readonly
                           style="width:100%;padding:.6rem .8rem;border:1px solid #E4E4EC;border-radius:8px;font-size:.9rem;background:#F4F5F9;color:#9AA0AE"/>
                  </div>
                  <div>
                    <label style="display:block;font-size:.8rem;color:#5A5F72;margin-bottom:.4rem;font-weight:600">Phone</label>
                    <input name="phone" value="<%= admin?.phone || '' %>"
                           style="width:100%;padding:.6rem .8rem;border:1px solid #E4E4EC;border-radius:8px;font-size:.9rem"/>
                  </div>
                  <div>
                    <label style="display:block;font-size:.8rem;color:#5A5F72;margin-bottom:.4rem;font-weight:600">Profile image</label>
                    <input type="file" name="image" accept="image/*"
                           style="width:100%;padding:.45rem;border:1px solid #E4E4EC;border-radius:8px;font-size:.85rem"/>
                  </div>
                </div>

                <div style="margin-bottom:1.2rem">
                  <label style="display:block;font-size:.8rem;color:#5A5F72;margin-bottom:.4rem;font-weight:600">Address</label>
                  <textarea name="address" rows="3"
                            style="width:100%;padding:.6rem .8rem;border:1px solid #E4E4EC;border-radius:8px;font-size:.9rem;font-family:inherit;resize:vertical"><%= admin?.address || '' %></textarea>
                </div>

                <button type="submit"
                        style="background:#D63384;border:none;color:#fff;padding:.65rem 1.4rem;border-radius:8px;font-size:.9rem;font-weight:600;cursor:pointer">
                  Save Profile
                </button>
              </form>
            </div>

            <div class="pro-panel">
              <h3>Change Password</h3>
              <form action="/admin/profile/password" method="post">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.2rem;max-width:480px">
                  <div>
                    <label style="display:block;font-size:.8rem;color:#5A5F72;margin-bottom:.4rem;font-weight:600">Current Password</label>
                    <input name="current" type="password" required
                           style="width:100%;padding:.6rem .8rem;border:1px solid #E4E4EC;border-radius:8px;font-size:.9rem"/>
                  </div>
                  <div>
                    <label style="display:block;font-size:.8rem;color:#5A5F72;margin-bottom:.4rem;font-weight:600">New Password</label>
                    <input name="newPassword" type="password" required
                           style="width:100%;padding:.6rem .8rem;border:1px solid #E4E4EC;border-radius:8px;font-size:.9rem"/>
                  </div>
                </div>

                <button type="submit"
                        style="background:#1E1E2A;border:none;color:#fff;padding:.65rem 1.4rem;border-radius:8px;font-size:.9rem;font-weight:600;cursor:pointer">
                  Change Password
                </button>
              </form>
            </div>

          </div>
        </div>

      </main>
    </div>

  </div>
</body>
</html>