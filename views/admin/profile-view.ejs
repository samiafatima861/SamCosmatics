<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Profile', pageCss: 'admin' }) %>
</head>
<body>
  <header class="site-header admin-header">
    <div class="container admin-header-inner">
      <a class="logo" href="/">SamCosmetics</a>
      <div class="admin-nav">
        <a href="/admin/profile" class="admin-profile-link">
          <img src="<%= admin?.image_url || '/images/placeholder.png' %>" alt="profile" class="admin-avatar-sm"/>
          <span><%= admin?.name %></span>
        </a>
        <form action="/admin/logout" method="post" style="display:inline">
          <button class="btn btn-dark btn-logout">Logout</button>
        </form>
      </div>
    </div>
  </header>

  <main class="container admin-main admin-main--narrow">
    <div class="profile-header">
      <img src="<%= admin?.image_url || '/images/placeholder.png' %>" alt="admin" class="admin-avatar-lg"/>
      <div>
        <h1><%= admin?.name %></h1>
        <p><%= admin?.email %></p>
      </div>
    </div>

    <dl class="profile-details">
      <dt><strong>Phone</strong></dt><dd><%= admin?.phone || '—' %></dd>
      <dt><strong>Address</strong></dt><dd><%= admin?.address || '—' %></dd>
    </dl>

    <div class="dashboard-section--tight">
      <a href="/admin/profile/edit" class="btn btn-pink">Edit profile</a>
    </div>
  </main>
</body>
</html>