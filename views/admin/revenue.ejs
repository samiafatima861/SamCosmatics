<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Revenue', styles: ['admin-layout', 'revenue-pro'] }) %>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <div class="admin-layout">

      <%- include('../partials/admin-sidebar', { active: 'orders' }) %>

    <div class="pro-page">
      <header class="pro-topbar">
        <h2>Revenue</h2>
        <div class="pro-topbar-actions">
          <button class="pro-icon-btn">🔔</button>
          <button class="pro-icon-btn">⚙️</button>
        </div>
      </header>

      <div class="pro-content">

        <!-- Stat cards -->
        <div class="pro-stat-grid">
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-blue">💵</div>
              <div>
                <div class="pro-stat-title">$<%= summary.totalSales.toFixed(2) %></div>
                <div class="pro-stat-sub">Total Sales</div>
              </div>
            </div>
          </div>

          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-orange">📦</div>
              <div>
                <div class="pro-stat-title">$<%= summary.totalCost.toFixed(2) %></div>
                <div class="pro-stat-sub">Total Cost</div>
              </div>
            </div>
          </div>

          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-green">📈</div>
              <div>
                <div class="pro-stat-title">$<%= summary.profit.toFixed(2) %></div>
                <div class="pro-stat-sub">Net Profit</div>
              </div>
            </div>
            <div class="pro-ring" style="background:conic-gradient(#1E9E5A <%= Math.min(summary.margin,100) %>%, #EAEAF0 0)">
              <span class="pro-ring-value"><%= summary.margin.toFixed(0) %>%</span>
            </div>
          </div>

          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-purple">%</div>
              <div>
                <div class="pro-stat-title"><%= summary.margin.toFixed(1) %>%</div>
                <div class="pro-stat-sub">Profit Margin</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Trend chart -->
        <div class="pro-panel">
          <h3>Revenue Trend (Last 30 Days)</h3>
          <div style="height:280px">
            <canvas id="revenueTrendChart"></canvas>
          </div>
          <div class="pro-summary-strip">
            <div class="pro-summary-item">
              <div class="value">$<%= summary.totalSales.toFixed(2) %></div>
              <div class="label">Total Sales <span class="up">↑</span></div>
            </div>
            <div class="pro-summary-item">
              <div class="value">$<%= summary.profit.toFixed(2) %></div>
              <div class="label">Net Profit <span class="up">↑</span></div>
            </div>
          </div>
        </div>

        <div class="pro-panel-row">
          <!-- Revenue by status table -->
          <div class="pro-panel">
            <h3>Revenue by Order Status</h3>
            <table class="pro-table">
              <thead><tr><th>Status</th><th>Orders</th><th>Revenue</th></tr></thead>
              <tbody>
                <% byStatus.forEach(s => { %>
                  <tr>
                    <td><span class="pro-pill pill-<%= s.status === 'delivered' || s.status === 'completed' ? 'approved' : (s.status === 'cancelled' || s.status === 'rejected' ? 'rejected' : (s.status === 'pending' ? 'pending' : 'processing')) %>"><%= s.status %></span></td>
                    <td><%= s.order_count %></td>
                    <td>$<%= Number(s.revenue).toFixed(2) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <!-- Donut chart: revenue by payment method -->
          <div class="pro-panel">
            <h3>Payment Methods</h3>
            <div class="pro-donut-wrap">
              <div style="width:180px;height:180px">
                <canvas id="paymentDonutChart"></canvas>
              </div>
              <div class="pro-legend" id="paymentLegend"></div>
            </div>
          </div>
        </div>

        <!-- Top products -->
        <div class="pro-panel">
          <h3>Top Revenue-Generating Products</h3>
          <table class="pro-table">
            <thead><tr><th>Product</th><th>Units Sold</th><th>Revenue</th></tr></thead>
            <tbody>
              <% topSelling.forEach(p => { %>
                <tr>
                  <td>
                    <div class="pro-product-cell">
                      <img src="<%= p.image_url || '/images/placeholder.png' %>"/>
                      <span><%= p.name %></span>
                    </div>
                  </td>
                  <td><%= p.units_sold %></td>
                  <td>$<%= Number(p.revenue).toFixed(2) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>

  <script>
    const dailySales = <%- JSON.stringify(dailySales) %>;
    const byPayment = <%- JSON.stringify(byPayment) %>;

    new Chart(document.getElementById('revenueTrendChart'), {
      type: 'line',
      data: {
        labels: dailySales.map(d => new Date(d.day).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })),
        datasets: [{
          label: 'Revenue ($)',
          data: dailySales.map(d => Number(d.revenue)),
          borderColor: '#3E7FC4',
          backgroundColor: 'rgba(62,127,196,0.08)',
          fill: true,
          tension: 0.4,
          pointRadius: 0,
          borderWidth: 2.5
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, grid: { color: '#F0F0F5' } },
          x: { grid: { display: false } }
        }
      }
    });

    const donutColors = ['#7C5CD6', '#3E7FC4', '#E38F2E', '#1E9E5A', '#E0554F'];
    new Chart(document.getElementById('paymentDonutChart'), {
      type: 'doughnut',
      data: {
        labels: byPayment.map(p => p.payment_method),
        datasets: [{
          data: byPayment.map(p => Number(p.revenue)),
          backgroundColor: donutColors,
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '70%',
        plugins: { legend: { display: false } }
      }
    });

    const legendEl = document.getElementById('paymentLegend');
    byPayment.forEach((p, i) => {
      const item = document.createElement('div');
      item.className = 'pro-legend-item';
      item.innerHTML = `<span class="pro-legend-dot" style="background:${donutColors[i % donutColors.length]}"></span> ${p.payment_method}`;
      legendEl.appendChild(item);
    });
  </script>
</body>
</html>