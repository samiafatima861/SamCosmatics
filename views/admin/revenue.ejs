<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Revenue</title>
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/admin.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <header class="site-header"><div class="container"><a class="logo" href="/">SamCosmetics</a></div></header>
  <main class="container admin-main">
    <div class="page-header"><h1>Revenue</h1></div>
    <p class="page-subtext">A full breakdown of sales, cost, and profit.</p>

    <div class="stat-grid" style="margin-bottom:2rem">
      <div class="stat-card blue">
        <div class="stat-card-icon">💵</div>
        <div class="stat-card-value">$<%= summary.totalSales.toFixed(2) %></div>
        <div class="stat-card-label">Total Sales</div>
      </div>
      <div class="stat-card orange">
        <div class="stat-card-icon">📦</div>
        <div class="stat-card-value">$<%= summary.totalCost.toFixed(2) %></div>
        <div class="stat-card-label">Total Cost</div>
      </div>
      <div class="stat-card pink">
        <div class="stat-card-icon">📈</div>
        <div class="stat-card-value">$<%= summary.profit.toFixed(2) %></div>
        <div class="stat-card-label">Net Profit</div>
      </div>
      <div class="stat-card muted" style="border-style:solid">
        <div class="stat-card-icon">%</div>
        <div class="stat-card-value" style="color:#241F1F"><%= summary.margin.toFixed(1) %>%</div>
        <div class="stat-card-label" style="color:#7A6C68">Profit Margin</div>
      </div>
    </div>

    <section class="dash-section" style="margin-bottom:1.5rem">
      <h2>Revenue Trend (Last 30 Days)</h2>
      <div style="height:280px">
        <canvas id="revenueTrendChart"></canvas>
      </div>
    </section>

    <div class="chart-grid" style="margin-bottom:1.5rem">
      <section class="dash-section">
        <h2>Revenue by Order Status</h2>
        <table class="product-table">
          <thead><tr><th>Status</th><th>Orders</th><th>Revenue</th></tr></thead>
          <tbody>
            <% byStatus.forEach(s => { %>
              <tr>
                <td><span class="status-badge status-<%= s.status %>"><%= s.status %></span></td>
                <td><%= s.order_count %></td>
                <td>$<%= Number(s.revenue).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>

      <section class="dash-section">
        <h2>Revenue by Payment Method</h2>
        <table class="product-table">
          <thead><tr><th>Method</th><th>Orders</th><th>Revenue</th></tr></thead>
          <tbody>
            <% byPayment.forEach(p => { %>
              <tr>
                <td><%= p.payment_method %></td>
                <td><%= p.order_count %></td>
                <td>$<%= Number(p.revenue).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    </div>

    <section class="dash-section">
      <h2>Top Revenue-Generating Products</h2>
      <table class="product-table">
        <thead><tr><th>Image</th><th>Product</th><th>Units Sold</th><th>Revenue</th></tr></thead>
        <tbody>
          <% topSelling.forEach(p => { %>
            <tr>
              <td><img src="<%= p.image_url || '/images/placeholder.png' %>" style="width:44px;height:44px;object-fit:cover;border-radius:6px"/></td>
              <td><%= p.name %></td>
              <td><%= p.units_sold %></td>
              <td>$<%= Number(p.revenue).toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>

  <script>
    const dailySales = <%- JSON.stringify(dailySales) %>;
    new Chart(document.getElementById('revenueTrendChart'), {
      type: 'line',
      data: {
        labels: dailySales.map(d => new Date(d.day).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })),
        datasets: [{
          label: 'Revenue ($)',
          data: dailySales.map(d => Number(d.revenue)),
          borderColor: '#D63384',
          backgroundColor: 'rgba(214,51,132,0.12)',
          fill: true,
          tension: 0.35,
          pointRadius: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true } }
      }
    });
  </script>
</body>
</html>