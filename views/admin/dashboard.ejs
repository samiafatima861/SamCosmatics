<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Admin Dashboard', styles: ['admin-layout', 'revenue-pro'] }) %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <div class="admin-layout">

    <%- include('../partials/admin-sidebar', { active: 'dashboard' }) %>

    <!-- Main -->
    <div>
      <header class="admin-topbar">
        <h2>Dashboard</h2>
        <div class="admin-topbar-account">
           <a href="/admin/notifications" class="notif-bell">
              🔔
             <% if (stats.notifications > 0) { %>
              <span class="notif-badge"><%= stats.notifications %></span>
             <% } %>
           </a>

          <img src="<%= admin?.image_url || '/images/placeholder.png' %>" alt="admin" class="admin-topbar-avatar"/>
          <span class="admin-topbar-name"><%= admin?.name %></span>
          <form action="/admin/logout" method="post">
            <button type="submit">Logout</button>
          </form>
        </div>

      </header>

      <main class="admin-content">
        <h1>Welcome, <%= admin?.name %></h1>

        <div class="stat-grid">
          <a href="/admin/adminProducts" class="stat-card pink stat-card-link">
            <div class="stat-card-icon">🛍️</div>
            <div class="stat-card-value"><%= stats.products %></div>
            <div class="stat-card-label">Products</div>
          </a>

          <a href="/admin/orders" class="stat-card blue stat-card-link">
            <div class="stat-card-icon">📦</div>
            <div class="stat-card-value"><%= stats.orders %></div>
            <div class="stat-card-label">Orders</div>
          </a>

          <a href="/admin/revenue" class="stat-card orange stat-card-link">
            <div class="stat-card-icon">💰</div>
            <div class="stat-card-value">$<%= stats.revenue.toFixed(2) %></div>
            <div class="stat-card-label">Total Revenue</div>
          </a>

          <a href="/admin/customers" class="stat-card blue stat-card-link">
            <div class="stat-card-icon">🧑‍🤝‍🧑</div>
            <div class="stat-card-value"><%= stats.customers %></div>
            <div class="stat-card-label">Customers</div>
          </a>

          <a href="/admin/sellers" class="stat-card pink stat-card-link">
            <div class="stat-card-icon">🏪</div>
            <div class="stat-card-value"><%= stats.sellers %></div>
            <div class="stat-card-label">Sellers</div>
          </a>

          <a href="/admin/notifications" class="stat-card muted stat-card-link" style="border-style:solid;background:linear-gradient(135deg,#6C63FF,#5B4FE0);color:#fff">
            <div class="stat-card-icon">🔔</div>
            <div class="stat-card-value"><%= stats.notifications %></div>
            <div class="stat-card-label">New Notifications</div>
          </a>
        </div>

        <% if (lowStock.length) { %>
          <div class="pro-panel">
            <h3>⚠️ Low Stock Alert</h3>
            <table class="pro-table">
              <thead><tr><th>Product</th><th>Stock Remaining</th></tr></thead>
              <tbody>
                <% lowStock.forEach(p => { %>
                  <tr>
                    <td>
                      <div class="pro-product-cell">
                        <img src="<%= p.image_url || '/images/placeholder.png' %>"/>
                        <span><%= p.name %></span>
                      </div>
                    </td>
                    <td><span class="pro-pill pill-pending"><%= p.stock_quantity %> left</span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <div class="chart-grid">
          <section class="dash-section">
            <h2>Sales Trend (Last 7 Days)</h2>
            <canvas id="salesTrendChart" height="180"></canvas>
          </section>

          <section class="dash-section">
            <h2>Product Stock Levels</h2>
            <canvas id="stockChart" height="180"></canvas>
          </section>
        </div>

        <section class="dash-section" style="margin-top:1.5rem">
          <h2>Top Selling Products</h2>

          <% if (!topSelling.length) { %>
            <p style="color:#9AA0AE;font-size:.9rem">No sales data yet — this will populate once orders start coming in.</p>
          <% } else { %>
            <% const maxUnits = Math.max(...topSelling.map(p => Number(p.units_sold))); %>
            <div class="top-selling-list">
              <% topSelling.forEach((p, idx) => { %>
                <div class="top-selling-row">
                  <div class="top-selling-rank">#<%= idx + 1 %></div>
                  <img src="<%= p.image_url || '/images/placeholder.png' %>" class="top-selling-thumb"/>
                  <div class="top-selling-info">
                    <strong><%= p.name %></strong>
                    <div class="top-selling-bar-track">
                      <div class="top-selling-bar-fill" style="width:<%= (p.units_sold / maxUnits * 100).toFixed(0) %>%"></div>
                    </div>
                  </div>
                  <div class="top-selling-stats">
                    <div><%= p.units_sold %> sold</div>
                    <div class="top-selling-revenue">$<%= Number(p.revenue).toFixed(2) %></div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

        <section class="dash-section" style="margin-top:1.5rem">
          <h2>Top Sellers</h2>

          <% if (!topSellers.length) { %>
            <p style="color:#9AA0AE;font-size:.9rem">No seller sales yet.</p>
          <% } else { %>
            <% const maxSellerRevenue = Math.max(...topSellers.map(s => Number(s.revenue))); %>
            <div class="top-selling-list">
              <% topSellers.forEach((s, idx) => { %>
                <div class="top-selling-row">
                  <div class="top-selling-rank">#<%= idx + 1 %></div>
                  <img src="<%= s.image_url || '/images/placeholder.png' %>" class="top-selling-thumb" style="border-radius:50%"/>
                  <div class="top-selling-info">
                    <strong><%= s.name %></strong>
                    <div class="top-selling-bar-track">
                      <div class="top-selling-bar-fill" style="width:<%= (s.revenue / maxSellerRevenue * 100).toFixed(0) %>%"></div>
                    </div>
                  </div>
                  <div class="top-selling-stats">
                    <div><%= s.units_sold %> sold</div>
                    <div class="top-selling-revenue">$<%= Number(s.revenue).toFixed(2) %></div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

        <div class="pro-stat-grid" style="margin-bottom:1rem;margin-top:1.5rem">
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-blue">🛍️</div>
              <div>
                <div class="pro-stat-title"><%= stockSummary.totalProducts %></div>
                <div class="pro-stat-sub">Total Products</div>
              </div>
            </div>
          </div>
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-green">✅</div>
              <div>
                <div class="pro-stat-title"><%= stockSummary.healthy %></div>
                <div class="pro-stat-sub">Healthy Stock</div>
              </div>
            </div>
          </div>
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-orange">⚠️</div>
              <div>
                <div class="pro-stat-title"><%= stockSummary.low %></div>
                <div class="pro-stat-sub">Low Stock</div>
              </div>
            </div>
          </div>
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-red">⛔</div>
              <div>
                <div class="pro-stat-title"><%= stockSummary.outOfStock %></div>
                <div class="pro-stat-sub">Out of Stock</div>
              </div>
            </div>
          </div>
        </div>

        <div class="pro-panel-row">
          <div class="pro-panel">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.1rem">
              <h3 style="margin:0">Stock Inventory</h3>
              <a href="/admin/inventory" style="font-size:.8rem;color:#5A5F72;text-decoration:none">View full inventory →</a>
            </div>

            <div style="display:flex;gap:.75rem;margin-bottom:1.1rem">
              <input type="text" id="inventory-search" placeholder="Search product name..." style="flex:1;max-width:280px;padding:.55rem .8rem;border:1px solid #E4E4EC;border-radius:8px;font-size:.9rem"/>
              <button type="button" id="inventory-reset" style="background:#F4F5F9;border:none;color:#5A5F72;padding:.55rem 1rem;border-radius:8px;cursor:pointer;font-size:.85rem">Reset</button>
            </div>

            <div style="max-height:380px;overflow-y:auto">
              <table class="pro-table" id="inventory-table">
                <thead>
                  <tr><th>Product</th><th>Variant</th><th>Stock</th><th>Status</th></tr>
                </thead>
                <tbody>
                  <% inventory.forEach(p => { %>
                    <% if (p.variants.length === 0) { %>
                      <tr class="inventory-row" data-name="<%= p.name.toLowerCase() %>">
                        <td>
                          <div class="pro-product-cell">
                            <img src="<%= p.image_url || '/images/placeholder.png' %>"/>
                            <span><%= p.name %></span>
                          </div>
                        </td>
                        <td>—</td>
                        <td><%= p.stock_quantity %></td>
                        <td>
                          <% if (p.stock_quantity <= 0) { %>
                            <span class="pro-pill pill-rejected">Out of stock</span>
                          <% } else if (p.stock_quantity <= 5) { %>
                            <span class="pro-pill pill-pending">Low stock</span>
                          <% } else { %>
                            <span class="pro-pill pill-approved">Healthy</span>
                          <% } %>
                        </td>
                      </tr>
                    <% } else { %>
                      <% p.variants.forEach((v, idx) => { %>
                        <tr class="inventory-row" data-name="<%= p.name.toLowerCase() %>">
                          <td>
                            <% if (idx === 0) { %>
                              <div class="pro-product-cell">
                                <img src="<%= p.image_url || '/images/placeholder.png' %>"/>
                                <span><%= p.name %></span>
                              </div>
                            <% } %>
                          </td>
                          <td><%= v.variant_name %></td>
                          <td><%= v.stock_quantity %></td>
                          <td>
                            <% if (v.stock_quantity <= 0) { %>
                              <span class="pro-pill pill-rejected">Out of stock</span>
                            <% } else if (v.stock_quantity <= v.low_stock_threshold) { %>
                              <span class="pro-pill pill-pending">Low stock</span>
                            <% } else { %>
                              <span class="pro-pill pill-approved">Healthy</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="pro-panel">
            <h3>Stock Health</h3>
            <div class="pro-donut-wrap">
              <div style="width:180px;height:180px">
                <canvas id="stockHealthChart"></canvas>
              </div>
              <div class="pro-legend">
                <div class="pro-legend-item"><span class="pro-legend-dot" style="background:#1E9E5A"></span> Healthy (<%= stockSummary.healthy %>)</div>
                <div class="pro-legend-item"><span class="pro-legend-dot" style="background:#E38F2E"></span> Low (<%= stockSummary.low %>)</div>
                <div class="pro-legend-item"><span class="pro-legend-dot" style="background:#E0554F"></span> Out (<%= stockSummary.outOfStock %>)</div>
              </div>
            </div>
          </div>
        </div>

      </main>
    </div>

  </div>

  <script>
    const dailySales = <%- JSON.stringify(dailySales) %>;
    const allProducts = <%- JSON.stringify(allProducts) %>;

    new Chart(document.getElementById('salesTrendChart'), {
      type: 'line',
      data: {
        labels: dailySales.map(d => new Date(d.day).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })),
        datasets: [{
          label: 'Revenue ($)',
          data: dailySales.map(d => Number(d.revenue)),
          borderColor: '#D63384',
          backgroundColor: 'rgba(214,51,132,0.12)',
          fill: true,
          tension: 0.35,
          pointRadius: 3
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true } }
      }
    });

    new Chart(document.getElementById('stockChart'), {
      type: 'bar',
      data: {
        labels: allProducts.map(p => p.name),
        datasets: [{
          label: 'Stock Quantity',
          data: allProducts.map(p => p.stock_quantity),
          backgroundColor: '#4A90D9',
          borderRadius: 6
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true } }
      }
    });

    new Chart(document.getElementById('stockHealthChart'), {
      type: 'doughnut',
      data: {
        labels: ['Healthy', 'Low', 'Out of Stock'],
        datasets: [{
          data: [<%= stockSummary.healthy %>, <%= stockSummary.low %>, <%= stockSummary.outOfStock %>],
          backgroundColor: ['#1E9E5A', '#E38F2E', '#E0554F'],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '70%',
        plugins: { legend: { display: false } }
      }
    });

    const invSearch = document.getElementById('inventory-search');
    const invReset = document.getElementById('inventory-reset');
    const invRows = document.querySelectorAll('.inventory-row');

    invSearch.addEventListener('input', () => {
      const term = invSearch.value.toLowerCase().trim();
      invRows.forEach(row => {
        row.style.display = row.dataset.name.includes(term) ? '' : 'none';
      });
    });

    invReset.addEventListener('click', () => {
      invSearch.value = '';
      invRows.forEach(row => row.style.display = '');
    });
  </script>
</body>
</html>