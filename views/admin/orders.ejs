<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Orders</title>
  <link rel="stylesheet" href="/css/products.css"/>
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
  <header class="site-header"><div class="container"><a class="logo" href="/">SamCosmetics</a></div></header>
  <main class="container admin-main">
    <div class="page-header">
      <h1>Orders</h1>
    </div>
    <p class="page-subtext">All orders placed on SamCosmetics.</p>

    <% if (!orders.length) { %>
      <div class="empty-state">No orders yet.</div>
    <% } else { %>
      <table class="product-table">
        <thead>
          <tr><th>#</th><th>Customer</th><th>Total</th><th>Status</th><th>Payment</th><th>Date</th><th></th></tr>
        </thead>
        <tbody>
          <% orders.forEach(o => { %>
            <tr>
              <td><%= o.id %></td>
              <td><%= o.customer_name %><br/><small><%= o.customer_email %></small></td>
              <td>$<%= Number(o.total).toFixed(2) %></td>
              <td><span class="status-badge status-<%= o.status %>"><%= o.status %></span></td>
              <td><%= o.payment_method %></td>
              <td><%= new Date(o.created_at).toLocaleDateString() %></td>
              <td><a href="/admin/orders/<%= o.id %>">View</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>