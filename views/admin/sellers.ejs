<!doctype html>
<html>
<head>
  <%- include('../partials/head', { title: 'Sellers', styles: ['admin-layout', 'revenue-pro'] }) %>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { active: 'sellers' }) %>

    <div class="pro-page">
      <header class="pro-topbar">
        <h2>Sellers</h2>
        <div class="pro-topbar-actions"><button class="pro-icon-btn">🔔</button></div>
      </header>

      <div class="pro-content">
        <div class="pro-stat-grid">
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-purple">🏪</div>
              <div><div class="pro-stat-title"><%= summary.total %></div><div class="pro-stat-sub">Total Sellers</div></div>
            </div>
          </div>
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-orange">⏳</div>
              <div><div class="pro-stat-title"><%= summary.pending %></div><div class="pro-stat-sub">Pending Review</div></div>
            </div>
          </div>
          <div class="pro-stat-card">
            <div class="pro-stat-left">
              <div class="pro-icon-badge badge-green">✅</div>
              <div><div class="pro-stat-title"><%= summary.approved %></div><div class="pro-stat-sub">Approved</div></div>
            </div>
          </div>
        </div>

        <div class="pro-panel">
          <h3>All Sellers</h3>
          <% if (!sellers.length) { %>
            <p style="color:#8A8FA3">No sellers have applied yet.</p>
          <% } else { %>
            <table class="pro-table">
              <thead><tr><th>Name</th><th>Email</th><th>Status</th><th>Products</th><th>Units Sold</th><th>Revenue</th><th>Actions</th></tr></thead>
              <tbody>
                <% sellers.forEach(s => { %>
                  <tr>
                    <td><%= s.name %></td>
                    <td><%= s.email %></td>
                    <td><span class="pro-pill pill-<%= s.status === 'approved' ? 'approved' : (s.status === 'rejected' ? 'rejected' : 'pending') %>"><%= s.status %></span></td>
                    <td><%= s.product_count %></td>
                    <td><%= s.units_sold %></td>
                    <td>$<%= Number(s.revenue).toFixed(2) %></td>
                    <td>
                      <% if (s.status !== 'approved') { %>
                        <form action="/admin/sellers/<%= s.id %>/approve" method="post" style="display:inline">
                          <button type="submit" style="background:#E8F7EE;color:#1E9E5A;border:none;padding:.35rem .7rem;border-radius:6px;cursor:pointer;font-size:.8rem">Approve</button>
                        </form>
                      <% } %>
                      <% if (s.status !== 'rejected') { %>
                        <form action="/admin/sellers/<%= s.id %>/reject" method="post" style="display:inline">
                          <button type="submit" style="background:#FDECEC;color:#E0554F;border:none;padding:.35rem .7rem;border-radius:6px;cursor:pointer;font-size:.8rem;margin-left:.3rem">Reject</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>